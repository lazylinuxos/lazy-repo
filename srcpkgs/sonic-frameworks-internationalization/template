# Template file for 'sonic-frameworks-internationalization'
pkgname=sonic-frameworks-internationalization
version=6.28.0
revision=1
build_style=cmake
configure_args="-DKDE_INSTALL_QMLDIR=lib/qt6/qml
 -DKDE_INSTALL_QTPLUGINDIR=lib/qt6/plugins"
hostmakedepends="sonic-frameworks-cmake-modules qt6-tools qt6-base
 qt6-declarative-host-tools gettext python3"
makedepends="qt6-declarative-devel"
depends="iso-codes"
short_desc="Gettext-based UI text internationalization"
maintainer="nerdyslacker <karyan40024@gmail.com>"
license="LGPL-2.1-or-later"
homepage="https://github.com/Sonic-DE/sonic-frameworks-internationalization"
distfiles="https://github.com/Sonic-DE/sonic-frameworks-internationalization/archive/refs/tags/${version}.tar.gz"
checksum=324782a53a151d987cdb18bfb399ddab48851b5c932439516ee9457ad122d431
provides="kf6-ki18n-${version}_${revision}"
conflicts="kf6-ki18n"
replaces="kf6-ki18n>=0"

do_check() {
	cd build
	# disable failing tests
	ctest -E "kcountrytest|kcountrysubdivisiontest|ki18n-klocalizedstringtest|kcatalogtest"
}

sonic-frameworks-internationalization-devel_package() {
    provides="kf6-ki18n-devel-${version}_${revision}"
    conflicts="kf6-ki18n-devel"
    replaces="kf6-ki18n-devel>=0"    
	depends="$makedepends ${sourcepkg}>=${version}_${revision}"
	short_desc+=" - development files"
	pkg_install() {
		vmove usr/include
		vmove usr/lib/cmake
		vmove "usr/lib/*.so"
	}
}
