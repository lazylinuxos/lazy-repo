sonic-frameworks-holidays-devel_package() {
    provides="kf6-kholidays-devel-${version}_${revision}"
    conflicts="kf6-kholidays-devel"
    replaces="kf6-kholidays-devel>=0"   
	depends="$makedepends ${sourcepkg}>=${version}_${revision}"
