# Template file for 'gram-bin'
pkgname=gram-bin
version=2.0.0
revision=1
archs="x86_64"
create_wrksrc=yes

hostmakedepends="tar"
depends="vulkan-loader mesa-vulkan-intel intel-video-accel"
short_desc="Code editor for humanoid apes and grumpy toads"
maintainer="nerdyslacker <karyan40024@gmail.com>"
license="AGPL-3.0-or-later, Apache-2.0, GPL-3.0-or-later"
homepage="https://gram.liten.app"
distfiles="https://codeberg.org/GramEditor/gram/releases/download/${version}/gram-linux-x86_64-${version}.tar.gz"
checksum=ab147f0cc6d8ba48ad0fbaa1235d8da737482c5823ae974ffa61252ebe91d436
conflicts="gram>=0"
replaces="gram>=0"
noshlibprovides=yes

do_install() {
	vmkdir opt/gram/bin
	vcopy ${wrksrc}/gram.app/bin/* opt/gram/bin

	vmkdir opt/gram/lib
	vcopy ${wrksrc}/gram.app/lib/* opt/gram/lib

	vmkdir opt/gram/libexec
	vcopy ${wrksrc}/gram.app/libexec/* opt/gram/libexec

	vmkdir usr/share
	vcopy ${wrksrc}/gram.app/share/* usr/share

	# link the binary
	vmkdir usr/bin/
	ln -s /opt/gram/bin/gram ${DESTDIR}/usr/bin/
	vlicense ${FILESDIR}/LICENSE-GPL
	vlicense ${FILESDIR}/LICENSE-APACHE
}
