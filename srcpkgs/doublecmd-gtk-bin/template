# Template file for 'doublecmd-gtk-bin'
pkgname=doublecmd-gtk-bin
version=1.2.7
revision=1
archs="x86_64"
create_wrksrc=yes

hostmakedepends="tar xz"
short_desc="Twin-panel (commander-style) file manager"
maintainer="nerdyslacker <karyan40024@gmail.com>"
license="GPL-2.0-or-later"
homepage="http://doublecmd.sourceforge.net/"
distfiles="https://github.com/doublecmd/doublecmd/releases/download/v${version}/doublecmd-${version}.gtk2.x86_64.tar.xz"
checksum="dddaa19ea5ecd87c1ce2b0d24749c014e2a5878e4de9c33629c37cc7d1ac6a2b"
nopie=yes
noshlibprovides=yes

do_install() {
	vmkdir usr/lib/doublecmd
	vcopy ${wrksrc}/doublecmd/* usr/lib/doublecmd

	vinstall ${wrksrc}/doublecmd/doublecmd.png 644 usr/share/pixmaps
	vinstall ${FILESDIR}/doublecmd.desktop 644 usr/share/applications

	vmkdir usr/bin/
	ln -s /usr/lib/doublecmd/doublecmd ${DESTDIR}/usr/bin/
}
