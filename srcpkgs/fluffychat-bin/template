# Template file for 'fluffychat-bin'
pkgname=fluffychat-bin
version=2.8.0
revision=1
archs="x86_64"
depends="gtk+3 jsoncpp libsecret xdg-user-dirs zenity libwebkit2gtk41"
short_desc="Cutest instant messenger in the [matrix]"
maintainer="nerdyslacker <karyan40024@gmail.com>"
license="AGPL-3.0-only"
homepage="https://fluffy.chat"
distfiles="https://github.com/krille-chan/fluffychat/releases/download/v${version}/fluffychat-linux-x64.tar.gz"
checksum=a09e7cc038eebb9f4e551cfe3e7e7b28c9b79813810341d231ddbc29c4bea756

do_install() {
	vmkdir opt/fluffychat
	vcopy * opt/fluffychat

	vbin fluffychat

	vinstall data/flutter_assets/assets/logo/mini/logo_mini.png 644 usr/share/pixmaps fluffychat.png
	vinstall ${FILESDIR}/fluffychat.desktop 644 usr/share/applications
	vlicense ${FILESDIR}/LICENSE
}
