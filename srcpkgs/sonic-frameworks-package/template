# Template file for 'sonic-frameworks-package'
pkgname=sonic-frameworks-package
version=6.28.0
revision=1
build_style=cmake
hostmakedepends="extra-cmake-modules qt6-tools qt6-base kf6-kdoctools
 gettext"
makedepends="kf6-karchive-devel kf6-kcoreaddons-devel kf6-ki18n-devel
 kf6-kdoctools-devel"
short_desc="Installation and loading of additional content like scripts and images as packages"
maintainer="nerdyslacker <karyan40024@gmail.com>"
license="LGPL-2.1-or-later"
homepage="https://github.com/Sonic-DE/sonic-frameworks-package"
distfiles="https://github.com/Sonic-DE/sonic-frameworks-package/archive/refs/tags/${version}.tar.gz"
checksum=e04bdcc642fd321a973afe852ba7376f12c3fb732399ad2b84cd6819a65a822a
provides="kf6-kpackage-${version}_${revision}"
conflicts="kf6-kpackage"
replaces="kf6-kpackage>=0"

sonic-frameworks-package-devel_package() {
	provides="kf6-kpackage-devel-${version}_${revision}"
	conflicts="kf6-kpackage-devel"
	replaces="kf6-kpackage-devel>=0"	
	depends="$makedepends ${sourcepkg}>=${version}_${revision}"
	short_desc+=" - development files"
	pkg_install() {
		vmove usr/include
		vmove usr/lib/cmake
		mkdir -p "${DESTDIR}/usr/lib/cmake/KF6Package"
		mv ${PKGDESTDIR}/usr/lib/cmake/KF6Package/KF6PackageTools* \
			"${DESTDIR}/usr/lib/cmake/KF6Package"
		vmove "usr/lib/*.so"
	}
}
