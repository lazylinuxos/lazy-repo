do_check() {
	cd build
	# disable failing tests
	ctest -E "kstandardactiontest"
}

sonic-frameworks-settings-ui-devel_package() {
	provides="kf6-kconfigwidgets-devel-${version}_${revision}"
	conflicts="kf6-kconfigwidgets-devel"
	replaces="kf6-kconfigwidgets-devel>=0"    
	depends="${sourcepkg}>=${version}_${revision} kf6-kcodecs-devel
	 kf6-kconfig-devel kf6-kwidgetsaddons-devel kf6-kcolorscheme-devel
	 qt6-base-devel"
	short_desc+=" - development files"
	pkg_install() {
		vmove usr/include
		vmove usr/lib/cmake
		vmove "usr/lib/*.so"
	}
}
