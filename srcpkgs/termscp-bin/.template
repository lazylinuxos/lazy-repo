# Template file for 'termscp-bin'
pkgname=termscp-bin
_pkgname=termscp
version=${VERSION}
revision=1
hostmakedepends="tar xz"
depends="dbus-glib libsmbclient pkg-config"
short_desc="Feature rich terminal file transfer"
maintainer="nerdyslacker <karyan40024@gmail.com>"
license="MIT"
homepage="https://termscp.veeso.dev"
distfiles="https://github.com/veeso/termscp/releases/download/v${version}/${_pkgname}_${version}-${revision}_amd64.deb"
checksum=${SHA256}
replaces="termscp"
noverifyrdeps=yes
disable_shlib_provides=yes

do_extract() {
	mkdir -p ${DESTDIR}
	ar x ${XBPS_SRCDISTDIR}/${pkgname}-${version}/${_pkgname}_${version}-${revision}_amd64.deb
}

do_install() {
	tar xf data.tar.xz -C ${DESTDIR}
	vlicense ${FILESDIR}/LICENSE
}
