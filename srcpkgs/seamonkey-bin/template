# Template file for 'seamonkey-bin'
pkgname=seamonkey-bin
version=2.53.23
revision=1
archs="x86_64"
create_wrksrc=yes
hostmakedepends="tar"
depends="desktop-file-utils mime-types"
short_desc="SeaMonkey internet suite"
maintainer="nerdyslacker <karyan40024@gmail.com>"
license="MPL-2.0"
homepage="https://www.seamonkey-project.org"
distfiles="https://archive.seamonkey-project.org/releases/${version}/linux-x86_64/en-US/seamonkey-${version}.en-US.linux-x86_64.tar.bz2"
checksum=7cd28c68bef78a4bcdea6f966364df0db38ee3f7e6ac66cca80f1e9c2fde25ea
replaces="seamonkey>=0"

do_install() {
	vmkdir usr/lib
	vcopy ${wrksrc}/* usr/lib

	vmkdir usr/share
	vinstall ${FILESDIR}/seamonkey.desktop 644 usr/share/applications/

	for i in 16 22 24 32 48 64 128 256; do
		vinstall ${wrksrc}/seamonkey/chrome/icons/default/default$i.png 644 usr/share/icons/hicolor/${i}x${i}/apps ${pkgname}.png
	done

	# link the binary
	vmkdir usr/bin/
	ln -s /usr/lib/seamonkey/seamonkey-bin ${DESTDIR}/usr/bin/seamonkey
}
