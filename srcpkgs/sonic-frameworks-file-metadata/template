do_check() {
	cd build
	# Skip failing tests
	ctest -E "usermetadatawritertest"
}

sonic-frameworks-file-metadata-devel_package() {
	provides="kf6-kfilemetadata-devel-${version}_${revision}"
	conflicts="kf6-kfilemetadata-devel"
	replaces="kf6-kfilemetadata-devel>=0"
	depends="$makedepends ${sourcepkg}>=${version}_${revision}"
	short_desc+=" - development files"
	pkg_install() {
		vmove usr/include
		vmove usr/lib/cmake
		vmove "usr/lib/*.so"
	}
}
