# Template file for 'helium-bin'
pkgname=helium-bin
version=0.11.7.1
revision=1
archs="x86_64"
create_wrksrc=yes

hostmakedepends="tar xz"
depends="gtk+3 libXScrnSaver nss alsa-lib"
short_desc="Private, fast, and honest web browser"
maintainer="nerdyslacker <karyan40024@gmail.com>"
license="GPL-3.0-or-later"
homepage="https://helium.computer"
distfiles="https://github.com/imputnet/helium-linux/releases/download/${version}/helium-${version}-x86_64_linux.tar.xz"
checksum=57476b02588a07c1c59310c6f48f9b3d384b1f423f709a46f76bf768e45a5ff6

do_install() {
	# Install the files
	vmkdir usr/lib/helium
	vcopy helium-${version}-x86_64_linux/* usr/lib/helium

	vmkdir usr/share/applications
	vinstall ${FILESDIR}/helium.desktop 644 usr/share/applications
	vinstall helium-${version}-x86_64_linux/product_logo_256.png 644 usr/share/pixmaps helium.png
	vinstall helium-${version}-x86_64_linux/product_logo_256.png 644 usr/share/icons/hicolor/scalable/apps helium.png

	# link the binary
	vmkdir usr/bin/
	ln -s /usr/lib/helium/helium ${DESTDIR}/usr/bin/helium
}
