# Template file for 'podman-desktop-bin'
pkgname=podman-desktop-bin
version=${VERSION}
revision=1
archs="x86_64"
create_wrksrc=yes
hostmakedepends="tar"
short_desc="Graphical tool for developing on containers and Kubernetes"
maintainer="nerdyslacker <karyan40024@gmail.com>"
license="Apache-2.0"
homepage="https://podman-desktop.io/"
distfiles="https://github.com/podman-desktop/podman-desktop/releases/download/v${version}/podman-desktop-${version}-x64.tar.gz"
checksum=${SHA256}
nopie=yes
replaces="podman-desktop>=0"

do_install() {
	# Install the files
	vmkdir opt/podman-desktop
	vcopy podman-desktop-${version}-x64/* opt/podman-desktop

	vmkdir usr/share/applications
	vinstall ${FILESDIR}/podman-desktop.desktop 644 usr/share/applications
	vinstall ${FILESDIR}/podman-desktop.png 644 usr/share/pixmaps

	# link the binary
	vmkdir usr/bin/
	ln -s /opt/podman-desktop/podman-desktop ${DESTDIR}/usr/bin/
}
