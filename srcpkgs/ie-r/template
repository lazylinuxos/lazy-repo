# Template file for 'ie-r'
pkgname=ie-r
version=0.1.1
revision=1
build_style=cargo
hostmakedepends="pkg-config clang"
makedepends="wayland-devel pipewire-devel libxkbcommon-devel dbus-devel
 fontconfig-devel libX11-devel libXcursor-devel libXrandr-devel libXi-devel"
short_desc="Pixel-perfect color picker"
maintainer="nerdyslacker <karyan40024@gmail.com>"
license="custom:IE-R"
homepage="https://github.com/miaupaw/ie-r"
distfiles="https://github.com/miaupaw/ie-r/archive/refs/tags/v${version}.tar.gz"
checksum=37bbac810bc7c1b7a8750336bc1236371493201a829c5ea25e21bb81a5de0cb2

post_install() {
	vmkdir usr/share/applications/
	vmkdir usr/share/icons/hicolor/scalable/apps/
	vinstall assets/ie-r.desktop 644 usr/share/applications/
	sed -i 's|Exec=ie-r|Exec=/usr/bin/ie-r|' ${DESTDIR}/usr/share/applications/ie-r.desktop
	vinstall assets/ie-r.svg 644 usr/share/icons/hicolor/scalable/apps/
	vdoc README.md
	vlicense LICENSE
}
