# Template file for 'sonic-frameworks-gui-addons'
pkgname=sonic-frameworks-gui-addons
version=6.27.0
revision=1
build_style=cmake
_llvmver=21
configure_args="-DKDE_INSTALL_QMLDIR=lib/qt6/qml
 $(vopt_bool python BUILD_PYTHON_BINDINGS)"
hostmakedepends="doxygen qt6-tools qt6-base sonic-frameworks-cmake-modules
 $(vopt_if python "shiboken6 python3-build python3-setuptools llvm${_llvmver}")
 pkg-config qt6-declarative-host-tools"
makedepends="libX11-devel qt6-declarative-devel qt6-base-private-devel
 $(vopt_if python 'libshiboken6-devel libpyside6-devel python3-devel')"
depends="sonic-frameworks-gui-addons-geo-uri-handler"
short_desc="GUI helper components and utilities for SonicDE frameworks"
maintainer="nerdyslacker <karyan40024@gmail.com>"
license="LGPL-2.0-only OR LGPL-3.0-only"
homepage="https://github.com/Sonic-DE/sonic-frameworks-gui-addons"
distfiles="https://github.com/Sonic-DE/sonic-frameworks-gui-addons/archive/refs/tags/${version}.tar.gz"
checksum=5d463f4d99958ba93a48faeb2ad4d69ef593ce2c139154a42597af9a7766b7b0
provides="kf6-kguiaddons-${version}_${revision}"
conflicts="kf6-kguiaddons"
replaces="kf6-kguiaddons>=0"

build_options="python"
build_options_default="python"

export LLVM_INSTALL_DIR=/usr/lib/llvm/${_llvmver}

sonic-frameworks-gui-addons-geo-uri-handler_package() {
	provides="kf6-kguiaddons-geo-uri-handler-${version}_${revision}"
	replaces="kf6-kguiaddons-geo-uri-handler>=0"
	short_desc+=" - Geo URI handler"
	pkg_install() {
		vmove usr/share/applications
		vmove usr/bin/kde-geo-uri-handler
	}
}

sonic-frameworks-gui-addons-devel_package() {
	provides="kf6-kguiaddons-devel-${version}_${revision}"
	replaces="kf6-kguiaddons-devel>=0"
	depends="${sourcepkg}>=${version}_${revision} qt6-base-devel"
	short_desc+=" - development files"
	pkg_install() {
		vmove usr/lib/pkgconfig
		vmove usr/include
		vmove usr/lib/cmake
		vmove "usr/lib/*.so"
	}
}
