# Template file for 'sonic-frameworks-sso'
pkgname=sonic-frameworks-sso
version=8.61
revision=1
build_style=qmake
configure_args="LIBDIR=/usr/lib .."
conf_files="/etc/signond.conf"
hostmakedepends="pkg-config doxygen qt6-base"
makedepends="qt6-base-devel"
short_desc="Daemon providing SSO over D-Bus for the gSSO framework"
maintainer="nerdyslacker <karyan40024@gmail.com>"
license="LGPL-2.1-or-later"
homepage="https://github.com/Sonic-DE/sonic-frameworks-sso"
distfiles="https://github.com/Sonic-DE/sonic-frameworks-sso/archive/refs/tags/${version}.tar.gz"
checksum=897ed793e210227afea7a4996a15e6b58ce4912001396d9f70ec91f58d28a2cf
provides="signond-${version}_${revision}"
conflicts="signond"
replaces="signond>=0"

post_extract() {
	mkdir -p build-qt6
}

pre_configure() {
	build_wrksrc=build-qt6
}

do_build() {
	make -C build-qt6 ${make_jobs}
}

do_install() {
	make -C build-qt6 install DESTDIR=${DESTDIR} PREFIX=/usr \
		INSTALL_ROOT=${DESTDIR} STRIP=true
}

sonic-frameworks-sso-devel_package() {
    provides="signond-devel-${version}_${revision}"
    conflicts="signond-devel"
    replaces="signond-devel>=0"    
	short_desc+=" - development files"
	depends="qt6-base-devel ${sourcepkg}>=${version}_${revision}"
	pkg_install() {
		vmove usr/include
		vmove usr/lib/*.so
		vmove usr/lib/pkgconfig
		vmove usr/lib/*.a
		vmove usr/lib/cmake
	}
}
