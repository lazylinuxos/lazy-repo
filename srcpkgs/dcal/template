# Template file for 'dcal'
pkgname=dcal
version=0.2.5
revision=1
_dqml_commit="35c10dd"
build_style=gnu-makefile
build_helper="qemu"
hostmakedepends="go pkg-config automake"
makedepends="qt6-base-devel qt6-declarative-devel qt6-svg-devel qt6-wayland-devel qt6-tools-devel"
depends="font-inter ttf-material-icons"
short_desc="Standalone calendar app that brings all your calendars together"
maintainer="nerdyslacker <karyan40024@gmail.com>"
license="MIT"
homepage="https://danklinux.com"
distfiles="https://github.com/AvengeMedia/dankcalendar/archive/refs/tags/v${version}.tar.gz
 https://github.com/AvengeMedia/dank-qml-common/archive/${_dqml_commit}.tar.gz>dank-qml-common.tar.gz"
checksum="e9a9aab4f406087f5122bce525a58b4925dcaf552e1366d5823c6533137fcfda
 f49e50910640393f1015ffc8efd4e7dede777f46e3e35214e3c2bb6ce84873ce"
skip_extraction="dank-qml-common.tar.gz"

post_extract() {
	vsrcextract -C "${wrksrc}/dank-qml-common" "dank-qml-common.tar.gz"
}

do_install() {
	vbin core/bin/dcal

	vmkdir usr/share/quickshell/dankcal
	vcopy "quickshell/*" usr/share/quickshell/dankcal

	vdoc README.md

	vinstall assets/com.danklinux.dankcalendar.desktop 644 usr/share/applications
	vinstall assets/dankcalendar.svg 644 usr/share/icons/hicolor/scalable/apps/
	vlicense LICENSE

	vsv dcal
}

post_install() {
	for sh in bash fish zsh; do
		vtargetrun core/bin/dcal completion "$sh" > "dcal.$sh"
		vcompletion "dcal.$sh" "$sh" dcal
	done
}
