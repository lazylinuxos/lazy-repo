# Template file for 'ly'
pkgname=ly
version=1.4.1
revision=1
archs="x86_64"
conf_files="
 /etc/ly/config.ini
 /etc/pam.d/ly
 /etc/pam.d/ly-autologin"
hostmakedepends="pkg-config zig"
makedepends="pam-devel libxcb-devel"
depends="pam util-linux xorg-server xauth brightnessctl"
short_desc="Lightweight TUI display manager for Linux and BSD"
maintainer="nerdyslacker <karyan40024@gmail.com>"
license="WTFPL"
homepage="https://codeberg.org/fairyglade/ly"
distfiles="https://codeberg.org/fairyglade/ly/archive/v${version}.tar.gz"
checksum=16fe5f07cc7a23930880b14d905883644cdc4b574d1c146629f6b98ee8fbbab9
nopie=yes

do_build() {
	zig build installexe -Dinit_system=runit
}

do_install() {
	vbin zig-out/bin/ly

	vmkdir etc/ly
	vinstall res/config.ini 644 etc/ly
	vinstall res/pam.d/ly-linux 644 etc/pam.d ly
	vinstall res/pam.d/ly-linux-autologin 644 etc/pam.d ly-autologin
	vinstall res/setup.sh 755 etc/ly

	vcopy res/lang etc/ly
	vcopy res/custom-sessions etc/ly

	vmkdir etc/sv/ly
	for FILE in res/ly-runit-service/*; do
		vinstall ${FILE} 0755 etc/sv/ly
	done
}

post_install() {
	vlicense license.md
}
