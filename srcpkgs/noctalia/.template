# Template file for 'noctalia'
pkgname=noctalia
version=${VERSION}
revision=1
build_style=meson
hostmakedepends="just ninja pkg-config"
makedepends="sdbus-c++-devel cmake wayland-devel wayland-protocols freetype-devel fontconfig-devel cairo-devel
 pango-devel librsvg-devel libxkbcommon-devel polkit-devel pipewire-devel wireplumber-devel libcurl-devel
 libqalculate-devel pam-devel libepoxy-devel"
depends="ImageMagick brightnessctl ffmpeg qt6-multimedia cliphist cava wlsunset power-profiles-daemon ddcutil"
short_desc="Sleek and minimal desktop shell"
maintainer="nerdyslacker <karyan40024@gmail.com>"
license="MIT"
homepage="https://github.com/noctalia-dev/noctalia"
distfiles="https://github.com/noctalia-dev/noctalia/archive/v${version}-beta1.tar.gz"
checksum=${SHA256}
CXXFLAGS+=" -std=c++23"

post_install() {
	vlicense LICENSE
}

noctalia-shell_package() {
	depends="${sourcepkg}>=${version}_${revision}"
	short_desc+=" - transitional dummy package"
}
