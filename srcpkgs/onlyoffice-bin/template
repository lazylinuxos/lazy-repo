# Template file for 'onlyoffice-bin'
pkgname=onlyoffice-bin
version=9.4.0
revision=1
archs="x86_64"
hostmakedepends="tar xz"
depends="libstdc++ curl xdg-utils dejavu-fonts-ttf"
short_desc="Open-source office suite pack"
maintainer="nerdyslacker <karyan40024@gmail.com>"
license="AGPL-3.0-only"
homepage="https://www.onlyoffice.com/"
distfiles="https://github.com/ONLYOFFICE/DesktopEditors/releases/download/v${version}/onlyoffice-desktopeditors_amd64.deb"
checksum=4271434e81be42b1559fd989d24bf6d413482f278dc6a5e328202a4fc1a18649
nostrip=yes
replaces="onlyoffice>=0"

do_extract() {
	mkdir -p ${DESTDIR}
	ar x ${XBPS_SRCDISTDIR}/${pkgname}-${version}/onlyoffice-desktopeditors_amd64.deb
}

do_install() {
	tar xf data.tar.xz -C ${DESTDIR}
	vlicense ${FILESDIR}/LICENSE
}
