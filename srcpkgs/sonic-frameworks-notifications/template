# Template file for 'sonic-frameworks-notifications'
pkgname=sonic-frameworks-notifications
version=6.28.0
revision=1
build_style=cmake
_llvmver=21
configure_args="-DKDE_INSTALL_QMLDIR=lib/qt6/qml
 -DKDE_INSTALL_QTPLUGINDIR=lib/qt6/plugins
 $(vopt_bool python BUILD_PYTHON_BINDINGS)"
hostmakedepends="sonic-frameworks-cmake-modules qt6-tools qt6-base
 qt6-declarative-host-tools pkg-config sonic-frameworks-settings
 $(vopt_if python "python3-build python3-setuptools shiboken6 llvm${_llvmver}")"
makedepends="sonic-frameworks-settings-devel libcanberra-devel
 qt6-declarative-devel qt6-base-devel qt6-tools-devel
 $(vopt_if python 'libshiboken6-devel libpyside6-devel python3-devel')"
short_desc="Sonic Desktop notifications"
maintainer="nerdyslacker <karyan40024@gmail.com>"
license="LGPL-2.1-or-later"
homepage="https://github.com/Sonic-DE/sonic-frameworks-notifications"
distfiles="https://github.com/Sonic-DE/sonic-frameworks-notifications/archive/refs/tags/${version}.tar.gz"
checksum=d5026aa79c0e87f1a63311704a51cf5850d235f31230abdff0008719412cb34b
provides="kf6-knotifications-${version}_${revision}"
conflicts="kf6-knotifications"
replaces="kf6-knotifications>=0"

build_options="python"
build_options_default="python"

if [ "$CROSS_BUILD" ]; then
	configure_args+=" -DECM_SHIBOKEN_ARCH=$XBPS_CROSS_RUST_TARGET"
	configure_args+=" -DSYSROOT_INCLUDE_DIRS=$XBPS_CROSS_BASE/usr/include"
fi
export LLVM_INSTALL_DIR=/usr/lib/llvm/${_llvmver}

case "$XBPS_TARGET_MACHINE" in
	arm*) configure_args+=" -DSHIBOKEN_GENERATOR_EXTRA_FLAGS=--clang-option=-mfloat-abi=hard" ;;
esac

sonic-frameworks-notifications-devel_package() {
    provides="kf6-knotifications-devel-${version}_${revision}"
    conflicts="kf6-knotifications-devel"
    replaces="kf6-knotifications-devel>=0"
	depends="${sourcepkg}>=${version}_${revision} qt6-base-devel
	 libcanberra-devel sonic-frameworks-settings-devel"
	short_desc+=" - development files"
	pkg_install() {
		vmove usr/include
		vmove usr/lib/cmake
		vmove "usr/lib/*.so"
	}
}
