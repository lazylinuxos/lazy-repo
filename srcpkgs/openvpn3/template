 protobuf python3-packaging-bootstrap"
makedepends="glib-devel jsoncpp-devel libcap-ng-devel liblz4-devel util-linux-libs openssl-devel
 protobuf-devel tinyxml2-devel libnl3-devel gdbuspp"
