}

post_install() {
	vinstall ${FILESDIR}/openvpn3.rule 644 etc/repkg/rules/system
	vinstall ${FILESDIR}/sysusers-openvpn3.conf 644 usr/lib/sysusers.d/openvpn3.conf
	vlicense COPYRIGHT.md
}
