# Template file for 'drawy'
pkgname=drawy
version=1.0.0
revision=2
build_style=cmake
build_helper="qmake6"
configure_args="-DCMAKE_BUILD_TYPE=Release"
hostmakedepends="qt6-tools"
makedepends="qt6-base-devel qt6-tools-devel qt6-declarative-devel Vulkan-Headers"
depends="glibc hicolor-icon-theme libgcc"
short_desc="Infinite whiteboard tool"
maintainer="nerdyslacker <karyan40024@gmail.com>"
license="GPL-3.0-only"
homepage="https://invent.kde.org/graphics/drawy"
distfiles="https://invent.kde.org/graphics/drawy/-/archive/v${version}/drawy-v${version}.tar.gz"
