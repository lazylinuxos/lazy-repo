# Template file for 'drawy'
pkgname=drawy
version=${VERSION}
revision=1
build_style=cmake
build_helper="qmake6"
configure_args="-DCMAKE_BUILD_TYPE=Release"
hostmakedepends="qt6-tools"
makedepends="qt6-base-devel qt6-tools-devel qt6-declarative-devel Vulkan-Headers"
depends="glibc hicolor-icon-theme libgcc"
short_desc="Infinite whiteboard tool"
maintainer="nerdyslacker <karyan40024@gmail.com>"
license="GPL-3.0-only"
homepage="https://invent.kde.org/graphics/drawy"
distfiles="https://invent.kde.org/graphics/drawy/-/archive/${version}-alpha/drawy-${version}-alpha.tar.gz"
checksum=${SHA256}

do_install() {
	vbin build/drawy
	vinstall deploy/appimage/AppDir/usr/share/applications/drawy.desktop 644 usr/share/applications
	vinstall deploy/appimage/AppDir/usr/share/icons/hicolor/256x256/apps/drawy.png 644 usr/share/icons/hicolor/256x256/apps
}
