do_install() {
    vbin target/${RUST_TARGET}/release/wayscriber-configurator

    vinstall README.md 644 usr/share/doc/${pkgname}
    [ -f LICENSE ] && vinstall LICENSE 644 usr/share/licenses/${pkgname}
}
