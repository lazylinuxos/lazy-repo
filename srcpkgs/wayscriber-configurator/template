# Template file for 'wayscriber-configurator'
pkgname=wayscriber-configurator
version=0.9.12
revision=1
build_style=cargo
configure_args="--manifest-path configurator/Cargo.toml"
hostmakedepends="pkg-config"
makedepends="cairo-devel wayland-devel pango-devel libxkbcommon-devel gcc glibc-devel"
depends="cairo wayland pango libgcc glibc libxkbcommon"
