post_extract() {
	for _module in core desktop-{apps,sdk} dictionaries sdkjs{,-forms} web-apps build_tools document-templates core-fonts
	do
		vsrcextract -C "${wrksrc}/$_module" "$_module.tar.gz"
	done
	vsrcextract -C "${wrksrc}/core/Common/3dParty/icu/icu" "icu.tar.gz"
	vsrcextract -C "${wrksrc}/core/Common/3dParty/v8_89/depot_tools" "depot_tools.tar.gz"
	vsrcextract -C "${wrksrc}/core/Common/3dParty/v8_89/v8" "v8.tar.gz"
}

pre_configure() {
	export CFLAGS+=" -fPIC"
	export CXXFLAGS+=" -std=gnu++11"
	export CMAKE_POLICY_VERSION_MINIMUM=3.5

	mkdir -p build_tools/tools/linux/system_qt/gcc_64
	ln -sf /usr/bin build_tools/tools/linux/system_qt/gcc_64/bin
	ln -sf /usr/lib build_tools/tools/linux/system_qt/gcc_64/lib
	ln -sf /usr/lib/qt5/plugins build_tools/tools/linux/system_qt/gcc_64/plugins

	touch build_tools/tools/linux/packages_complete

	dos2unix core/Common/OfficeFileFormatChecker2.cpp

	sed -Ei '/pragma (end)?region/d' core/MsBinaryFile/XlsFile/Format/Logic/Biff_structures/StringPtgParser.cpp
	sed -i '1s/^/#include <unistd.h>\n/' core/OfficeUtils/src/zlib-1.2.11/gzwrite.c
	sed -i '1s/^/#include <unistd.h>\n/' core/OfficeUtils/src/zlib-1.2.11/gzread.c
	sed -i '1s/^/#include <unistd.h>\n/' core/OfficeUtils/src/zlib-1.2.11/gzlib.c
	sed -i '1s/^/#include<cmath>\n/' desktop-sdk/ChromiumBasedEditors/videoplayerlib/src/qtimelabel.cpp
	sed -i '1s/^/#include<cmath>\n/' desktop-sdk/ChromiumBasedEditors/videoplayerlib/src/qvideoslider.cpp
	sed -i '1s/^/#include<cmath>\n/' desktop-sdk/ChromiumBasedEditors/videoplayerlib/src/qvideoplaylist.cpp
	sed -i '1s/^/#include<QPainterPath>\n/' desktop-apps/win-linux/src/windows/platform_linux/cwindowplatform.cpp
	sed -i 's|http://|https://|' build_tools/scripts/core_common/modules/cef.py

	cd "${wrksrc}/build_tools"
	./configure.py --module desktop --update 0 --qt-dir "$(realpath tools/linux/system_qt)"
	./make.py --update-only

	if [ -d "${wrksrc}/core/Common/3dParty/v8_89" ]; then
		cd "${wrksrc}/core/Common/3dParty/v8_89"
		echo -n "v8_version_1" > v8.data
		cat > .gclient << EOF
solutions = [
	{
		"name": "v8",
		"url": "file://${XBPS_BUILDDIR}/v8@local",
		"deps_file": "DEPS",
		"managed": False,
		"custom_deps": {},
		"custom_vars": {},
	},
]
EOF

		export PATH="$(pwd)/depot_tools:${PATH}"
		export DEPOT_TOOLS_UPDATE=0

		if command -v gclient >/dev/null; then
			gclient sync --force
		fi

		mkdir -p v8/third_party/llvm-build/Release+Asserts/lib
		ln -sf /usr/lib/libstdc++.so.6 v8/third_party/llvm-build/Release+Asserts/lib/libstdc++.so.6
	fi

	# cd "${wrksrc}/build_tools"
	# ./make.py --update-third-party-only
}

do_build() {
	cd build_tools

	export QT_VERSION="$(qmake  -query QT_VERSION)"

	export CFLAGS="${CFLAGS/-O2/}"
	export CXXFLAGS="${CXXFLAGS/-O2/}"
	export CXXFLAGS="${CXXFLAGS/-Wp,-D_GLIBCXX_ASSERTIONS/}"

	python3 make.py --no-third-party-update
}

do_install() {
	cd build_tools

	python3 make_package.py	-P linux_x86_64	-T desktop -V "${version}" -B "${revision}"

	cd ../desktop-apps/package/tar

	tar xf onlyoffice-desktopeditors-"${version}"-"${revision}"-x86_64.tar.xz

	vmkdir usr
	vcopy usr /
	vcopy opt /

	ln -sf /usr/bin/onlyoffice-desktopeditors ${DESTDIR}/usr/bin/desktopeditors

	rm -f ${DESTDIR}/opt/onlyoffice/desktopeditors/libQt5*
	rm -f ${DESTDIR}/opt/onlyoffice/desktopeditors/libicu*
}

post_install() {
	vlicense LICENSE
}
