# Template file for 'sonic-frameworks-bluetooth'
pkgname=sonic-frameworks-bluetooth
version=6.28.0
revision=1
build_style=cmake
configure_args="-DKDE_INSTALL_QMLDIR=lib/qt6/qml"
hostmakedepends="sonic-frameworks-cmake-modules qt6-tools qt6-base
 qt6-declarative-host-tools"
makedepends="qt6-declarative-devel"
checkdepends="dbus"
short_desc="Qt wrapper for Bluez 5 D-Bus API"
maintainer="nerdyslacker <karyan40024@gmail.com>"
license="LGPL-2.1-or-later"
homepage="https://github.com/Sonic-DE/sonic-frameworks-bluetooth"
distfiles="https://github.com/Sonic-DE/sonic-frameworks-bluetooth/archive/refs/tags/${version}.tar.gz"
checksum=3658e5268f1956fd25b32b5090665460235122e7bab1492f8045b453b46a3b13
provides="kf6-bluez-qt-${version}_${revision}"
conflicts="kf6-bluez-qt"
replaces="kf6-bluez-qt>=0"

do_check() {
	cd build
	dbus-run-session ctest -E "bluezqt-managertest"
}

sonic-frameworks-bluetooth-devel_package() {
    provides="kf6-bluez-qt-devel-${version}_${revision}"
    conflicts="kf6-bluez-qt-devel"
    replaces="kf6-bluez-qt-devel>=0"
	depends="$makedepends ${sourcepkg}>=${version}_${revision}"
	short_desc+=" - development files"
	pkg_install() {
		vmove usr/include
		vmove usr/lib/cmake
		vmove usr/lib/pkgconfig
		vmove "usr/lib/*.so"
	}
}
