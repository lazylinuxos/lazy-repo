# Template file for 'flow-control-bin'
pkgname=flow-control-bin
version=0.7.2
revision=1
archs="x86_64"

short_desc="A programmer's text editor (binary release)"
maintainer="nerdyslacker <karyan40024@gmail.com>"
license="MIT"
homepage="https://github.com/neurocyte/flow"
distfiles="https://github.com/neurocyte/flow/releases/download/v${version}/flow-v${version}-linux-x86_64.tar.gz"
checksum="3f647aa06e3910d047a72b2c0d8af222b9f0f4f9325d8778f72d58acad1f8157"
conflicts="flow-control"

do_install() {
    vbin flow
    vinstall ${FILESDIR}/LICENSE 644 "usr/share/licenses/${pkgname}"
    vinstall ${FILESDIR}/flow-control.desktop 644 "usr/share/applications"
    vinstall ${FILESDIR}/flow-control.png 644 "usr/share/pixmaps"
}
