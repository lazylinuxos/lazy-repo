provides="kquickimageeditor-${version}_${revision}"
conflicts="kquickimageeditor"
replaces="kquickimageeditor>=0"

sonic-quick-image-editor-devel_package() {
	provides="kquickimageeditor-devel-${version}_${revision}"
	conflicts="kquickimageeditor-devel"
	replaces="kquickimageeditor-devel>=0"
	depends="${makedepends} ${sourcepkg}>=${version}_${revision}"
	short_desc+=" - development files"
	pkg_install() {
		vmove usr/include
		vmove usr/lib/cmake
		vmove usr/lib/qt6/mkspecs
	}
}
