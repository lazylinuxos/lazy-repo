build_style=cmake
configure_args="-DBUILD_WITH_QT6=ON -DKDE_INSTALL_QMLDIR=lib/qt6/qml
 -DECM_MKSPECS_INSTALL_DIR=/usr/lib/qt6/mkspecs/modules
 -DKDE_INSTALL_QTPLUGINDIR=lib/qt6/plugins"
hostmakedepends="sonic-frameworks-cmake-modules sonic-frameworks-settings qt6-base qt6-tools
 qt6-declarative-host-tools"
makedepends="sonic-frameworks-settings-devel qt6-base-devel qt6-declarative-devel libopencv-devel"
short_desc="QtQuick-based image editing components"
