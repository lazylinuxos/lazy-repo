do_check() {
	cd build
	dbus-run-session ctest
}

sonic-frameworks-modemmanager-devel_package() {
    provides="kf6-modemmanager-qt-devel-${version}_${revision}"
    conflicts="kf6-modemmanager-qt-devel"
    replaces="kf6-modemmanager-qt-devel>=0"    
	depends="$makedepends ${sourcepkg}>=${version}_${revision}"
	short_desc+=" - development files"
	pkg_install() {
		vmove usr/include
		vmove usr/lib/cmake
		vmove "usr/lib/*.so"
	}
}
