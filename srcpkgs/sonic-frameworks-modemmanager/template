# Template file for 'sonic-frameworks-modemmanager'
pkgname=sonic-frameworks-modemmanager
version=6.27.0
revision=1
build_style=cmake
hostmakedepends="sonic-frameworks-cmake-modules qt6-tools qt6-base
 pkg-config"
makedepends="qt6-base-devel ModemManager-devel"
checkdepends="dbus"
short_desc="Qt wrapper for ModemManager DBus API"
maintainer="nerdyslacker <karyan40024@gmail.com>"
license="LGPL-2.1-or-later"
homepage="https://github.com/Sonic-DE/sonic-frameworks-modemmanager"
distfiles="https://github.com/Sonic-DE/sonic-frameworks-modemmanager/archive/refs/tags/${version}.tar.gz"
