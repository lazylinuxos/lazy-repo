# Template file for 'sonic-frameworks-settings-utils'
pkgname=sonic-frameworks-settings-utils
version=6.27.0
revision=1
build_style=cmake
build_helper=qemu
configure_args="-DKF6_HOST_TOOLING=/usr/lib/cmake
 -DKDE_INSTALL_QMLDIR=lib/qt6/qml
 -DKDE_INSTALL_LIBEXECDIR=libexec"
hostmakedepends="sonic-frameworks-cmake-modules gettext qt6-tools qt6-base
 qt6-declarative-host-tools sonic-frameworks-settings"
makedepends="sonic-frameworks-settings-ui-devel sonic-frameworks-core-addons-devel sonic-frameworks-io-devel
 sonic-frameworks-xml-gui-devel sonic-frameworks-settings-devel qt6-declarative-devel sonic-frameworks-quick-ui-devel"
checkdepends="sonic-frameworks-quick-ui"
short_desc="Utilities for Sonic System Settings modules"
maintainer="nerdyslacker <karyan40024@gmail.com>"
license="LGPL-2.1-or-later"
homepage="https://github.com/Sonic-DE/sonic-frameworks-settings-utils"
distfiles="https://github.com/Sonic-DE/sonic-frameworks-settings-utils/archive/refs/tags/${version}.tar.gz"
checksum=14ec6fc42198f76cad26cebc7bdd9b803a5bee29fdd1618454e3b94551ea3cdd
provides="kf6-kcmutils-${version}_${revision}"
conflicts="kf6-kcmutils"
replaces="kf6-kcmutils>=0"

sonic-frameworks-settings-utils-devel_package() {
	provides="kf6-kcmutils-devel-${version}_${revision}"
	conflicts="kf6-kcmutils-devel"
	replaces="kf6-kcmutils-devel>=0"
	depends="${sourcepkg}>=${version}_${revision}
	 sonic-frameworks-settings-ui-devel sonic-frameworks-core-addons-devel
	 qt6-declarative-devel"
	short_desc+=" - development files"
	pkg_install() {
		vmove usr/include
		vmove usr/lib/cmake
		mkdir -p "${DESTDIR}/usr/lib/cmake/KF6KCMUtils"
		mv ${PKGDESTDIR}/usr/lib/cmake/KF6KCMUtils/KF6KCMUtilsTool* \
			"${DESTDIR}/usr/lib/cmake/KF6KCMUtils/"
		vmove "usr/lib/*.so"
	}
}
