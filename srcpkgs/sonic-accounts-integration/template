	depends+=" signon-ui"
fi

sonic-accounts-integration-devel_package() {
    provides="kf6-kaccounts-integration-devel-${version}_${revision}"
    conflicts="kf6-kaccounts-integration-devel"
    replaces="kf6-kaccounts-integration-devel>=0"    
	short_desc+=" - development files"
	depends="${sourcepkg}>=${version}_${revision} qt6-base-devel
	 libaccounts-qt6-devel signond-devel sonic-frameworks-core-addons-devel"
	pkg_install() {
		vmove usr/include
		vmove usr/lib/cmake
		vmove "usr/lib/*.so"
	}
}
