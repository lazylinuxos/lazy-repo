# Template file for 'sonic-frameworks-silver-icons'
pkgname=sonic-frameworks-silver-icons
version=6.28.0
revision=1
build_style=cmake
configure_args="-DINSTALL_HOST_TOOLS=ON"
hostmakedepends="extra-cmake-modules qt6-base qt6-tools python3-lxml libxml2"
makedepends="qt6-base-devel"
checkdepends="fdupes"
short_desc="Silver icon theme"
maintainer="nerdyslacker <karyan40024@gmail.com>"
license="LGPL-3.0-or-later"
homepage="https://github.com/Sonic-DE/sonic-frameworks-silver-icons"
distfiles="https://github.com/Sonic-DE/sonic-frameworks-silver-icons/archive/refs/tags/${version}.tar.gz"
checksum=abdace1e7ec006c4fe42a7415bc93bf7a6c4df32165daf88644725d6ade72ed8
provides="breeze-icons-${version}_${revision}"
conflicts="breeze-icons"
replaces="breeze-icons>=0"
nostrip=yes

if [ -z "$CROSS_BUILD" ]; then
	configure_args+=" -DBINARY_ICONS_RESOURCE=ON"
else
	hostmakedepends+=" libbreeze-icons-devel"
	configure_args+=" -DBINARY_ICONS_RESOURCE=OFF"
fi

sonic-frameworks-silver-icons-library_package() {
	provides="libbreeze-icons-${version}_${revision}"
	conflicts="libbreeze-icons"
	replaces="libbreeze-icons>=0"    
	pkg_install() {
		vmove "usr/lib/*.so.*"
	}
}

sonic-frameworks-silver-icons-library-devel_package() {
	provides="libbreeze-icons-devel-${version}_${revision}"
	conflicts="libbreeze-icons-devel"
	replaces="libbreeze-icons-devel>=0"    
	depends="libbreeze-icons>=${version}_${revision}"
	short_desc+=" - development files"
	pkg_install() {
		if [ -z "$CROSS_BUILD" ]; then
			vmove usr/bin
		fi
		vmove usr/include
		vmove usr/lib/cmake
		vmove "usr/lib/*.so"
	}
}
