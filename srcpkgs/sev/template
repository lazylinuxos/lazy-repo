# Template file for 'sev'
pkgname=sev
version=0.1.0
revision=1
_tree_sitter_version=0.26.8
_tree_sitter_scheme_version=0.24.7-1
build_style=cmake
configure_args="-DUSE_VENDORED=OFF"
hostmakedepends="pkg-config"
makedepends="libglvnd-devel SDL3-devel SDL3_image-devel SDL3_ttf-devel chibi-scheme-devel" # tree-sitter-devel tree-sitter-scheme
short_desc="Graphical Emacs-like text editor"
maintainer="nerdyslacker <karyan40024@gmail.com>"
license="MIT"
homepage="https://github.com/dylancobb/sev"
distfiles="https://github.com/dylancobb/sev/archive/refs/tags/v${version}.tar.gz
 https://github.com/tree-sitter/tree-sitter/archive/refs/tags/v${_tree_sitter_version}.tar.gz>tree-sitter.tar.gz
 https://github.com/6cdh/tree-sitter-scheme/archive/refs/tags/v${_tree_sitter_scheme_version}.tar.gz>tree-sitter-scheme.tar.gz"
checksum="b0fbe138548e247a610edac1dfb7d4bff4b6169ec61b66319a53df1a7a8eb65a
 e6826b7533ec3a885aba598377a6d20b5a6321ff3db76968e960c2352d3a5077
 64a549fae70004794ea75a08dd7d678e3971235813adf290b66f1cb6cb6d282f"
skip_extraction="
 tree-sitter.tar.gz
 tree-sitter-scheme.tar.gz"

post_extract() {
	vsrcextract -C "${wrksrc}/vendored/tree-sitter" "tree-sitter.tar.gz"
	vsrcextract -C "${wrksrc}/vendored/tree-sitter-scheme" "tree-sitter-scheme.tar.gz"
}

do_install() {
	vmkdir usr/lib/sev
	vcopy build/resources usr/lib/sev/
	vcopy build/scheme usr/lib/sev/
	vcopy build/app usr/lib/sev/

	vinstall build/resources/icon.png 644 usr/share/pixmaps sev.png
	vinstall ${FILESDIR}/sev.desktop 644 usr/share/applications

	vmkdir usr/bin/
	ln -s /usr/lib/sev/app ${DESTDIR}/usr/bin/sev

	vlicense LICENSE
}
