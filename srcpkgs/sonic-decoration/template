sonic-decoration-devel_package() {
    provides="kf6-kdecoration-devel-${version}_${revision}"
    conflicts="kf6-kdecoration-devel"
    replaces="kf6-kdecoration-devel>=0"
	conflicts="kdecoration-devel>=0"
	depends="${makedepends} ${sourcepkg}>=${version}_${revision}"
	short_desc+=" - development files"
	pkg_install() {
		vmove usr/include
		vmove usr/lib/cmake
		vmove "usr/lib/*.so"
	}
}
