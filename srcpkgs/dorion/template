# Template file for 'dorion'
pkgname=dorion
version=6.12.2
revision=1
hostmakedepends="cargo rust nodejs pnpm cmake pkg-config patchelf"
makedepends="gtk+3-devel openssl-devel libwebkit2gtk41-devel libayatana-appindicator-devel librsvg-devel"
depends="gst-plugins-base1 gst-plugins-good1"
short_desc="Tiny Discord client with a smaller footprint"
maintainer="nerdyslacker <karyan40024@gmail.com>"
license="GPL-3.0-or-later"
homepage="https://github.com/SpikeHD/Dorion"
_shelter_build_commit=e6aa4a1
distfiles="https://github.com/SpikeHD/Dorion/archive/refs/tags/v${version}.tar.gz
 https://github.com/uwu/shelter-builds/archive/${_shelter_build_commit}.tar.gz>shelter-builds.tar.gz"
checksum="30a494d9ce589b33941377923fb7bd5ed5aaebb87928b6d4e0ecc4ba53877d7c
 a583c8163a49b072995ad8931d23d989675e02d313e619996235f2cf8f7acd5b"
skip_extraction="shelter-builds.tar.gz"

post_extract() {
	vsrcextract -C "${wrksrc}/src-tauri/injection" "shelter-builds.tar.gz"
}

do_configure() {
	pnpm install --frozen-lockfile
}

do_build() {
	pnpm build:updater

	cd ${wrksrc}/src-tauri/extension_webkit
	cmake .
	cmake --build .

	cd ${wrksrc}
	pnpm tauri build --no-bundle
}

do_install() {
	vbin src-tauri/target/release/Dorion dorion

	vinstall src-tauri/icons/128x128.png 644 usr/share/pixmaps dorion.png
	vinstall ${FILESDIR}/dorion.desktop 644 usr/share/applications
}
