# Template file for 'gram'
pkgname=gram
version=${VERSION}
revision=1
build_style=cargo
build_helper=rust
hostmakedepends="rust cargo-about clang cmake protobuf pkg-config gettext"
makedepends="alsa-lib-devel libcurl-devel fontconfig-devel libxcb-devel protobuf-devel
 glib-devel libxkbcommon-devel libX11-devel openssl-devel sqlite-devel Vulkan-Headers
 vulkan-loader-devel wayland-devel zlib-devel libzstd-devel libgit2-1.9-devel"
depends="nodejs netcat Vulkan-Tools"
short_desc="Code editor for humanoid apes and grumpy toads"
maintainer="nerdyslacker <karyan40024@gmail.com>"
license="GPL-3.0-or-later, AGPL-3.0-or-later, Apache-2.0"
homepage="https://gram.liten.app"
distfiles="https://codeberg.org/GramEditor/gram/archive/${version}.tar.gz"
checksum=${SHA256}
nocross=yes
_appid=se.ziran.Gram

pre_build() {
	cargo fetch --locked --target "$(rustc --print host-tuple)"

	export DO_STARTUP_NOTIFY="true"
	export APP_ICON="${pkgname}"
	export APP_NAME="Gram"
	export APP_CLI="${pkgname}"
	export APP_ID="${_appid}"
	export APP_ARGS="%U"
	envsubst < "crates/gram/resources/gram.desktop.in" > ${_appid}.desktop

	./script/generate-licenses
}

do_build() {
	CFLAGS+=' -ffat-lto-objects'
	CXXFLAGS+=' -ffat-lto-objects'
	RUSTFLAGS+=" --remap-path-prefix ${PWD}=/"
	export CARGO_TARGET_DIR=target
	export RELEASE_VERSION="$version"
	export PROTOC=/usr/bin/protoc
	export PROTOC_INCLUDE=/usr/include	
	cargo build --release --frozen --package gram --package cli
}

do_install() {
    vbin target/release/cli gram
    vinstall target/release/gram 0755 usr/lib/gram/ gram-editor
    vinstall ${_appid}.desktop 644 usr/share/applications/
    vinstall crates/gram/resources/app-icon.png 644 usr/share/pixmaps gram.png
}
