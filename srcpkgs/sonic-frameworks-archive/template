sonic-frameworks-archive-devel_package() {
	provides="kf6-karchive-devel-${version}_${revision}"
	conflicts="kf6-karchive-devel"
	replaces="kf6-karchive-devel>=0"
	depends="$makedepends ${sourcepkg}>=${version}_${revision}"
