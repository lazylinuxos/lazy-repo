# Template file for 'aerion'
pkgname=aerion
version=0.3.2
revision=1
archs="x86_64"
hostmakedepends="go wails nodejs pkg-config"
makedepends="glib-devel gtk+3-devel libwebkit2gtk41-devel"
short_desc="Open Source Lightweight E-Mail Client"
maintainer="nerdyslacker <karyan40024@gmail.com>"
license="Apache-2.0"
homepage="https://github.com/hkdb/aerion"
changelog="https://raw.githubusercontent.com/hkdb/aerion/refs/heads/main/CHANGELOG.md"
distfiles="https://github.com/hkdb/aerion/archive/refs/tags/v${version}.tar.gz"
checksum=a4b1c16e21561d8a46fd18af4764346672f794be51b8716982897615d30c3ddf
nopie=yes

do_build() {
	wails build -tags webkit2_41,linux,production
}

do_install() {
	vbin build/bin/aerion
	vinstall build/linux/aerion.png 644 usr/share/pixmaps io.github.hkdb.Aerion.png
	vinstall build/linux/aerion.desktop 644 usr/share/applications
}
