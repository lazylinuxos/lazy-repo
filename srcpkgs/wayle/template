# Template file for 'wayle'
pkgname=wayle
version=0.6.0
revision=1
build_style=cargo
make_build_args="--bin wayle --bin wayle-settings"
hostmakedepends="pkg-config clang llvm"
makedepends="gtk4-devel gtk4-layer-shell-devel gtksourceview5-devel
 pulseaudio-devel fftw-devel pipewire-devel eudev-libudev-devel"
short_desc="GTK4-based Wayland desktop panel and widgets"
maintainer="nerdyslacker <karyan40024@gmail.com>"
license="MIT"
homepage="https://github.com/wayle-rs/wayle"
distfiles="https://github.com/wayle-rs/wayle/archive/refs/tags/v${version}.tar.gz"
checksum=1d887b9378d04dcf29057d4c8fb8323341f4f0e7ef094feea8ddbdcbf4dfa72e

do_install() {
	vbin target/${RUST_TARGET}/release/wayle
	vbin target/${RUST_TARGET}/release/wayle-settings

	vinstall resources/com.wayle.settings.desktop 644 usr/share/applications
	vinstall resources/wayle-settings.svg 644 usr/share/icons/hicolor/scalable/apps

	vmkdir usr/share/wayle/icons
	vcopy resources/icons/* usr/share/wayle/icons/

	target/${RUST_TARGET}/release/wayle completions bash > wayle.bash
	target/${RUST_TARGET}/release/wayle completions zsh > _wayle
	target/${RUST_TARGET}/release/wayle completions fish > wayle.fish

	vinstall wayle.bash 644 usr/share/bash-completion/completions/wayle
	vinstall _wayle 644	usr/share/zsh/site-functions
	vinstall wayle.fish 644	usr/share/fish/vendor_completions.d

	vsv wayle
	vlicense LICENSE
	vdoc README.md
	vdoc ${FILESDIR}/README.voidlinux
}
