# Template file for 'sonic-frameworks-file-search'
pkgname=sonic-frameworks-file-search
version=6.27.0
revision=1
build_style=cmake
configure_args="-DKF6_HOST_TOOLING=/usr/lib/cmake
 -DKDE_INSTALL_QMLDIR=lib/qt6/qml
 -DKDE_INSTALL_QTPLUGINDIR=lib/qt6/plugins
 -DKDE_INSTALL_LIBEXECDIR=libexec"
hostmakedepends="sonic-frameworks-cmake-modules qt6-tools qt6-base
 qt6-declarative-host-tools gettext sonic-frameworks-settings-devel"
makedepends="qt6-declarative-devel sonic-frameworks-core-addons-devel sonic-frameworks-settings-devel
 sonic-frameworks-dbus-devel sonic-frameworks-internationalization-devel sonic-frameworks-idle-tracker-devel sonic-frameworks-device-integration-devel
 sonic-frameworks-crash-handler-devel sonic-frameworks-io-devel sonic-frameworks-file-metadata-devel lmdb-devel"
short_desc="Framework for searching and managing metadata"
