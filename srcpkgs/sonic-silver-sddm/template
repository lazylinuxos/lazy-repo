do_install() {
	vmkdir usr/share/sddm/themes/Sonic-Silver
	vmkdir usr/share/sddm/themes/Sonic-Silver-Light

	vcopy Sonic-Silver/* "usr/share/sddm/themes/Sonic-Silver"
	vcopy Sonic-Silver-Light/* "usr/share/sddm/themes/Sonic-Silver-Light"

	vdoc CHANGELOG
	vdoc README.md
}
