sonic-workspace-library_package() {
	provides="kworkspace-${version}_${revision}"
	conflicts="kworkspace"
	replaces="kworkspace>=0"
	short_desc="Sonic Workspace Library for KF6"
	pkg_install() {
		vmove "usr/lib/libkworkspace6.so.6*"
	}
}

sonic-workspace-x11_package() {
	short_desc+=" - X11 Session"
	depends="sonic-workspace"
	provides="plasma-workspace-x11-${version}_${revision}"
	conflicts="plasma-workspace-x11"
	replaces="plasma-workspace-x11>=0"
	pkg_install() {
		vmkdir usr/share/xsessions
		vmove usr/share/xsessions/plasmax11.desktop
	}
}

sonic-workspace-devel_package() {
	provides="plasma-workspace-devel-${version}_${revision}"
	conflicts="plasma-workspace-devel"
	replaces="plasma-workspace-devel>=0"
	short_desc+=" - development files"
	depends="sonic-workspace-library>=${version}_${revision} qt6-base-devel
	 qt6-declarative-devel sonic-frameworks-data-models-devel
	 ${sourcepkg}>=${version}_${revision}"
	pkg_install() {
		vmove usr/include
		vmove usr/lib/cmake
	}
}
