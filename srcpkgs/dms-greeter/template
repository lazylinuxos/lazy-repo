# Template file for 'dms-greeter'
pkgname=dms-greeter
_pkg1=DankMaterialShell
version=1.4.5
revision=1
archs="x86_64"
depends="greetd quickshell"
short_desc="DankMaterialShell greeter for greetd"
maintainer="nerdyslacker <karyan40024@gmail.com>"
license="GPL-3.0-only"
homepage="https://github.com/AvengeMedia/DankMaterialShell"
distfiles="https://github.com/AvengeMedia/${_pkg1}/archive/v${version}/${_pkg1}-${version}.tar.gz"
checksum=e72ecd397ec967b2b789df06876810369a86052da92636c1c28cbe6676a28920

do_install() {
	vbin quickshell/Modules/Greetd/assets/${pkgname}

	vmkdir usr/share/quickshell/${pkgname}
	vcopy quickshell/* usr/share/quickshell/${pkgname}/

	vmkdir usr/share/doc/${pkgname}
	vinstall quickshell/Modules/Greetd/README.md 644 usr/share/doc/${pkgname}/
}
