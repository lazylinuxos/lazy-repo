sonic-frameworks-autocomplete-devel_package() {
    provides="kf6-kcompletion-devel-${version}_${revision}"
    conflicts="kf6-kcompletion-devel"
    replaces="kf6-kcompletion-devel>=0"
	depends="$makedepends ${sourcepkg}>=${version}_${revision}"
