# Template file for 'sonic-frameworks-keyring'
pkgname=sonic-frameworks-keyring
version=6.28.0
revision=1
build_style=cmake
configure_args="-DKF6_HOST_TOOLING=/usr/lib/cmake"
hostmakedepends="extra-cmake-modules qt6-tools qt6-base
 gettext kf6-kdoctools kf6-kconfig pkg-config"
makedepends="kf6-kconfig-devel kf6-kcoreaddons-devel kf6-kcrash-devel
 kf6-kwindowsystem-devel kf6-kcolorscheme-devel kf6-kdbusaddons-devel
 kf6-knotifications-devel kf6-kwidgetsaddons-devel kf6-kdoctools-devel
 gpgmepp-devel qca-qt6-devel libgcrypt-devel libsecret-devel"
short_desc="Safe desktop-wide storage for passwords"
maintainer="nerdyslacker <karyan40024@gmail.com>"
license="LGPL-2.1-or-later"
homepage="https://github.com/Sonic-DE/sonic-frameworks-keyring"
distfiles="https://github.com/Sonic-DE/sonic-frameworks-keyring/archive/refs/tags/${version}.tar.gz"
checksum=f867b7f838ee4d26e7ddc761b2c2904a6c1859ea9cc7825fec501540b0d15504
provides="kf6-kwallet-${version}_${revision}"
conflicts="kf6-kwallet"
replaces="kf6-kwallet>=0"

# https://bugs.kde.org/show_bug.cgi?id=509680 / https://github.com/void-linux/void-packages/issues/57348
post_install() {
	rm ${DESTDIR}/usr/share/dbus-1/services/org.freedesktop.impl.portal.desktop.kwallet.service
}

sonic-frameworks-keyring-devel_package() {
    provides="kf6-kwallet-devel-${version}_${revision}"
    conflicts="kf6-kwallet-devel"
    replaces="kf6-kwallet-devel>=0"    
	depends="$makedepends ${sourcepkg}>=${version}_${revision}"
	short_desc+=" - development files"
	pkg_install() {
		vmove usr/include
		vmove usr/lib/cmake
		vmove "usr/lib/*.so"
	}
}
