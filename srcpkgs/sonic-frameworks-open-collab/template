short_desc="Qt library implementing Open Collaboration Services API (SonicDE fork)"
maintainer="nerdyslacker <karyan40024@gmail.com>"
license="LGPL-2.0-only OR LGPL-3.0-only"
homepage="https://github.com/Sonic-DE/sonic-frameworks-open-collab"
