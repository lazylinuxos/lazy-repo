provides="kf6-attica-${version}_${revision}"
conflicts="kf6-attica"
replaces="kf6-attica>=0"

do_check() {
	cd build
	ctest -E "providertest"
}

sonic-frameworks-open-collab-devel_package() {
	provides="kf6-attica-devel-${version}_${revision}"
	replaces="kf6-attica-devel>=0"
	depends="$makedepends ${sourcepkg}>=${version}_${revision}"
	short_desc+=" - development files"
	pkg_install() {
		vmove usr/lib/pkgconfig
		vmove usr/include
		vmove usr/lib/cmake
		vmove "usr/lib/*.so"
	}
}
