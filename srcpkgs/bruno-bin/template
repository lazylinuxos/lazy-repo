# Template file for 'bruno-bin'
pkgname=bruno-bin
_pkgname=bruno
version=3.3.0
revision=1
hostmakedepends="tar xz"
short_desc="Opensource IDE For Exploring and Testing Api's"
maintainer="nerdyslacker <karyan40024@gmail.com>"
license="MIT"
homepage="https://www.usebruno.com"
distfiles="https://github.com/usebruno/bruno/releases/download/v${version}/${_pkgname}_${version}_amd64_linux.deb"
checksum=d318c2b1adad00cd2e40e4255391f64b0564cc32b46b98c909c845e97d6762b8
nostrip=yes
replaces="bruno>=0"

do_extract() {
	mkdir -p ${DESTDIR}
	ar x ${XBPS_SRCDISTDIR}/${pkgname}-${version}/${_pkgname}_${version}_amd64_linux.deb
}

do_install() {
	tar xf data.tar.xz -C ${DESTDIR}
	vlicense ${FILESDIR}/license.md
}
