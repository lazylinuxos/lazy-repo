provides="libksysguard-${version}_${revision}"
conflicts="libksysguard"
replaces="libksysguard>=0"

do_check() {
	cd build
	ctest -E "processdatamodeltest|cgrouptest"
}

sonic-sysguard-library-devel_package() {
    provides="libksysguard-devel-${version}_${revision}"
    conflicts="libksysguard-devel"
    replaces="libksysguard-devel>=0"  
	short_desc+=" - development"
	depends="kf6-ki18n-devel kf6-kconfig-devel qt6-base-devel
	 ${sourcepkg}>=${version}_${revision}"
	pkg_install() {
		vmove usr/include
		vmove usr/lib/cmake
		vmove "usr/lib/*.so"
	}
}
