# Template file for 'sonic-screenlocker'
pkgname=sonic-screenlocker
version=6.7.3
revision=1
build_style=cmake
configure_args="-DBUILD_TESTING=OFF -DKF6_HOST_TOOLING=/usr/lib/cmake
 -DKDE_INSTALL_QTPLUGINDIR=lib/qt6/plugins
 -DKDE_INSTALL_LIBEXECDIR=libexec"
hostmakedepends="sonic-frameworks-cmake-modules pkg-config qt6-base qt6-tools gettext
 elogind kf6-kpackage kf6-kcmutils kf6-kconfig"
makedepends="kf6-kconfig-devel kf6-kcrash-devel kf6-kdeclarative-devel kf6-ki18n-devel
 kf6-kidletime-devel kf6-knotifications-devel kf6-kpackage-devel kf6-ksvg-devel
 kf6-kxmlgui-devel kf6-kcmutils-devel kf6-solid-devel libX11-devel libxcb-devel libXi-devel
 pam-devel qt6-base-private-devel qt6-declarative-devel sonic-frameworks-core-addons-devel
 sonic-frameworks-io-devel sonic-frameworks-keybind-devel sonic-frameworks-quick-ui-devel
 sonic-frameworks-windowsystem-devel sonic-interface-libraries-devel sonic-screen-library-devel
 xcb-util-keysyms-devel layer-shell-qt-devel"
short_desc="Library and components for secure lock screen architecture"
maintainer="nerdyslacker <karyan40024@gmail.com>"
license="LGPL-2.0-or-later"
homepage="https://github.com/Sonic-DE/sonic-screenlocker"
distfiles="https://github.com/Sonic-DE/sonic-screenlocker/archive/refs/tags/${version}.tar.gz"
checksum=8579de7e9e8a54462fd816259a505291ce69786a58736ad9a217c1d61f659b32
provides="kscreenlocker-${version}_${revision}"
conflicts="kscreenlocker"
replaces="kscreenlocker>=0"

post_install() {
	vinstall ${FILESDIR}/kde.pam 664 usr/lib/pam.d/kde
	vinstall ${FILESDIR}/kde-fingerprint.pam 664 usr/lib/pam.d/kde-fingerprint
	vinstall ${FILESDIR}/kde-smartcard.pam 664 usr/lib/pam.d/kde-smartcard
}

sonic-screenlocker-devel_package() {
	provides="kscreenlocker-devel-${version}_${revision}"
	conflicts="kscreenlocker-devel"
	replaces="kscreenlocker-devel>=0"
	short_desc+=" - development files"
	depends="${sourcepkg}>=${version}_${revision} qt6-base-devel"
	pkg_install() {
		vmove usr/include
		vmove usr/lib/cmake
		vmove "usr/lib/*.so"
	}
}
