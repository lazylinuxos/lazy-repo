# Template file for 'siproxylin'
pkgname=siproxylin
version=0.0.28
revision=1
hostmakedepends="python3 python3-pip patchelf file wget"
depends="python3 drunk-call-service"
short_desc="Encrypted self-hosted messaging app with VoIP and XMPP"
maintainer="nerdyslacker <karyan40024@gmail.com>"
license="MIT"
homepage="https://github.com/confund0/siproxylin"
distfiles="https://github.com/confund0/siproxylin/archive/refs/tags/v${version}.tar.gz"
checksum=61a908fda39e30c077e1944f8fdc729d6bf8de44a9a369c98537410d045db776
noverifyrdeps=yes
noshlibprovides=yes

do_install() {
	local _prefix="usr"

	vmkdir "${_prefix}/share/${pkgname}"
	vmkdir "${_prefix}/share/icons/hicolor/scalable/apps"
	vmkdir "${_prefix}/share/applications"

	vcopy siproxylin "${_prefix}/share/${pkgname}/"
	vcopy drunk_xmpp "${_prefix}/share/${pkgname}/"
	vcopy drunk_call_hook "${_prefix}/share/${pkgname}/"
	vcopy main.py "${_prefix}/share/${pkgname}/"
	vcopy version.sh "${_prefix}/share/${pkgname}/"

	vinstall siproxylin/resources/icons/siproxylin.svg 644 "${_prefix}/share/icons/hicolor/scalable/apps/"
	vinstall ${FILESDIR}/Siproxylin.desktop 644 "${_prefix}/share/applications/"

	python3 -m pip install --ignore-installed \
		--root="${DESTDIR}" \
		--prefix="${_prefix}" \
		-r requirements.txt \
		--no-warn-script-location \
		--quiet

	vbin ${FILESDIR}/siproxylin.sh siproxylin
	vlicense LICENSE
}
