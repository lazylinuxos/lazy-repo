# Template file for 'konform-browser-bin'
pkgname=konform-browser-bin
_pkgname=konform-browser
version=140.13.0.100rc1
revision=1
_version=140.13.0-100rc1
archs="x86_64"
build_style="fetch"
short_desc="Firefox ESR fork with increased security, privacy, and customizability"
maintainer="nerdyslacker <karyan40024@gmail.com>"
license="MPL-2.0"
homepage="https://konform-browser.codeberg.page"
distfiles="https://codeberg.org/api/packages/konform-browser/generic/konform-browser/${_version}/${_pkgname}-${_version}-linux-x86_64-deb.deb"
checksum=8425f766421f942a5abece43fa71c854440e089309fb32871d5037dbf40a3eff
replaces="konform-browser>=0"

do_install() {
	vextract -C ${DESTDIR} ${_pkgname}-${_version}-linux-x86_64-deb.deb

	vmkdir usr/lib
	mv ${DESTDIR}/usr/share/konform ${DESTDIR}/usr/lib

	ln -frs ${DESTDIR}/usr/lib/konform/konform ${DESTDIR}/usr/bin

	vsed -i 's|usr/share|usr/lib|g' ${DESTDIR}/usr/share/applications/konform.desktop
}
