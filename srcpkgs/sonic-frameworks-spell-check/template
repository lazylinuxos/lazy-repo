sonic-frameworks-spell-check-devel_package() {
	provides="kf6-sonnet-devel-${version}_${revision}"
	conflicts="kf6-sonnet-devel"
	replaces="kf6-sonnet-devel>=0"
	depends="$makedepends ${sourcepkg}>=${version}_${revision}"
	short_desc+=" - development files"
	pkg_install() {
		vmove usr/include
		vmove usr/lib/cmake
		vmove "usr/lib/*.so"
		vmove usr/lib/qt6/plugins/designer
	}
}
