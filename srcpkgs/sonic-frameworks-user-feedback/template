	cd build
	# disable failing test
	ctest -E "openglinfosourcetest"
}

sonic-frameworks-user-feedback-devel_package() {
    provides="kf6-kuserfeedback-devel-${version}_${revision}"
    conflicts="kf6-kuserfeedback-devel"
    replaces="kf6-kuserfeedback-devel>=0"     
	depends="$makedepends ${sourcepkg}>=${version}_${revision}"
	short_desc+=" - development files"
	pkg_install() {
		vmove usr/include
		vmove usr/lib/cmake
		vmove "usr/lib/*.so"
	}
}
