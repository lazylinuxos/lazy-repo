sonic-frameworks-feeds-devel_package() {
    provides="kf6-syndication-devel-${version}_${revision}"
    conflicts="kf6-syndication-devel"
    replaces="kf6-syndication-devel>=0"    
	depends="$makedepends ${sourcepkg}>=${version}_${revision}"
