# Template file for 'sonic-interface-libraries'
pkgname=sonic-interface-libraries
version=6.7.3
revision=1
build_style=cmake
configure_args="-DKF6_HOST_TOOLING=/usr/lib/cmake
 -DKDE_INSTALL_QMLDIR=lib/qt6/qml
 -DKDE_INSTALL_QTPLUGINDIR=lib/qt6/plugins"
hostmakedepends="qt6-base qt6-tools qt6-declarative-host-tools gettext pkg-config sonic-frameworks-settings
 sonic-frameworks-quick-ui-devel sonic-frameworks-cmake-modules sonic-frameworks-doctools 
 sonic-frameworks-windowsystem sonic-frameworks-settings-utils sonic-frameworks-package"
makedepends="sonic-frameworks-color-scheme-devel sonic-frameworks-settings-devel sonic-frameworks-internationalization-devel sonic-frameworks-icon-themes-devel
 sonic-frameworks-notifications-devel sonic-frameworks-package-devel sonic-frameworks-svg-devel sonic-frameworks-widgets-addons-devel
 libglvnd-devel libX11-devel libxcb-devel qt6-qt5compat-devel qt6-base-private-devel qt6-declarative-devel
 sonic-activities-devel sonic-frameworks-core-addons-devel sonic-frameworks-gui-addons-devel
 sonic-frameworks-io-devel sonic-frameworks-keybind-devel sonic-frameworks-quick-ui-devel
 sonic-frameworks-windowsystem-devel"
depends="sonic-frameworks-quick-ui"
