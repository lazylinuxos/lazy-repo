 qt6-declarative-host-tools gettext pkg-config kf6-kconfig sonic-frameworks-quick-ui-devel
 kf6-kcmutils sonic-frameworks-windowsystem kf6-kpackage"
makedepends="qt6-base-private-devel qt6-declarative-devel qt6-svg-devel
 kf6-kcmutils-devel kf6-ksvg-devel kf6-ki18n-devel sonic-frameworks-windowsystem-devel
 kf6-kpackage-devel kf6-kiconthemes-devel sonic-frameworks-gui-addons-devel kf6-karchive-devel
 kf6-kconfigwidgets-devel sonic-activities-devel sonic-frameworks-keybind-devel kf6-knotifications-devel
 sonic-frameworks-core-addons-devel sonic-frameworks-io-devel kf6-kcolorscheme-devel qt6-tools-devel
 qt6-qt5compat-devel libglvnd-devel libX11-devel libxcb-devel"
