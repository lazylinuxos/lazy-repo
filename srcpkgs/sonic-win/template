sonic-win-devel_package() {
	provides="kwin-x11-devel-${version}_${revision}"
	replaces="kwin-x11-devel>=0"
	depends="${sourcepkg}>=${version}_${revision}"
	short_desc+=" - development files"
	pkg_install() {
		vmove usr/include
		vmove usr/lib/cmake
		vmove "usr/lib/*.so"
	}
