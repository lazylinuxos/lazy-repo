sonic-frameworks-color-scheme-devel_package() {
	provides="kf6-kcolorscheme-devel-${version}_${revision}"
	conflicts="kf6-kcolorscheme-devel"
	replaces="kf6-kcolorscheme-devel>=0"
	depends="${sourcepkg}>=${version}_${revision}
	 sonic-frameworks-gui-addons-devel qt6-base-devel sonic-frameworks-internationalization-devel"
	short_desc+=" - development files"
	pkg_install() {
		vmove usr/include
		vmove usr/lib/cmake
		vmove "usr/lib/*.so"
	}
}
