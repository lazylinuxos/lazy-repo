# Template file for 'cattail'
pkgname=cattail
version=1.2.0
revision=1
archs="x86_64"
hostmakedepends="go wails nodejs pkg-config"
makedepends="libsoup3-devel libwebkit2gtk41-devel"
depends="tailscale openssh"
short_desc="Unofficial Tailscale client"
maintainer="nerdyslacker <karyan40024@gmail.com>"
license="GPL-3.0-or-later"
homepage="https://github.com/nerdyslacker/cattail"
distfiles="https://github.com/nerdyslacker/cattail/archive/refs/tags/v${version}.tar.gz"
checksum=5b169f22db16ca25d541ade229359530fc12ea64cd9a2adf03c3266c94b4bbd3
nopie=yes
noverifyrdeps=yes
noshlibprovides=yes

do_build() {
	wails build -tags webkit2_41,linux,production
}

do_install() {
	vbin build/bin/cattail
	vinstall ${FILESDIR}/cattail.desktop 644 usr/share/applications
	vinstall ${FILESDIR}/cattail.png 644 usr/share/pixmaps
}
