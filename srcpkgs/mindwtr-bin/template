# Template file for 'mindwtr-bin'
pkgname=mindwtr-bin
version=1.1.0
revision=1
hostmakedepends="tar xz"
depends="gtk+3 libwebkit2gtk41 libayatana-appindicator"
short_desc="Complete Getting Things Done (GTD) productivity system"
maintainer="nerdyslacker <karyan40024@gmail.com>"
license="AGPL-3.0-only"
homepage="https://github.com/dongdongbh/Mindwtr"
distfiles="https://github.com/dongdongbh/Mindwtr/releases/download/v${version}/mindwtr_${version}_amd64.deb"
checksum=ef5e52b2785c2a2da2ee44ad47744bacd66fa6c96dcfc7c9274ef14946de928f

do_extract() {
	mkdir -p ${DESTDIR}
	ar x ${XBPS_SRCDISTDIR}/${pkgname}-${version}/mindwtr_${version}_amd64.deb
}

do_install() {
	tar xf data.tar.gz -C ${DESTDIR}
	vlicense LICENSE
}
