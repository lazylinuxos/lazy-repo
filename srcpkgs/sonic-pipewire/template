# Template file for 'sonic-pipewire'
pkgname=sonic-pipewire
version=6.7.3
revision=1
build_style=cmake
configure_args="-DKDE_INSTALL_QMLDIR=lib/qt6/qml"
hostmakedepends="sonic-frameworks-cmake-modules gettext qt6-base qt6-tools pkg-config
 pipewire qt6-declarative-host-tools plasma-wayland-protocols"
makedepends="ffmpeg6-devel libva-devel libepoxy-devel pipewire-devel
 qt6-declarative-devel qt6-base-private-devel sonic-frameworks-core-addons-devel 
 sonic-frameworks-internationalization-devel"
depends="pipewire"
short_desc="Components to use PipeWire in Qt projects"
maintainer="nerdyslacker <karyan40024@gmail.com>"
license="GPL-3.0-or-later"
homepage="https://github.com/Sonic-DE/sonic-pipewire"
