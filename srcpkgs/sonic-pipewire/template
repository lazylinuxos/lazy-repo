provides="kpipewire-${version}_${revision}"
conflicts="kpipewire"
replaces="kpipewire>=0"

do_check() {
	cd build
	ctest -E "mediamonitortest"
}

sonic-pipewire-devel_package() {
    provides="kpipewire-devel-${version}_${revision}"
    conflicts="kpipewire-devel"
    replaces="kpipewire-devel>=0"    
	depends="${sourcepkg}>=${version}_${revision}
	 qt6-base-devel pipewire-devel"
	short_desc+=" - development files"
	pkg_install() {
		vmove usr/include
		vmove usr/lib/cmake
		vmove "usr/lib/*.so"
	}
}
