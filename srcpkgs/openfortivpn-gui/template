post_install() {
	vinstall data/com.github.shini4i.openfortivpn-gui.desktop 644 usr/share/applications
	vsv openfortivpn-gui-helper
	for size in 16 24 32 48 64 96 128 256 512; do
		vinstall assets/icons/hicolor/${size}x${size}/apps/openfortivpn-gui.png 644 \
			usr/share/icons/hicolor/${size}x${size}/apps
	done
}
